#!/bin/bash
#SBATCH --job-name=megahit_healthy1
#SBATCH --partition=cpu1.largem
#SBATCH --output=/home/jtay0094/megahit_healthy1_%j.out
#SBATCH --error=/home/jtay0094/megahit_healthy1_%j.err
#SBATCH --time=3-00:00:00
#SBATCH --cpus-per-task=16
#SBATCH --mem=64G

set -eo pipefail

source /home/jtay0094/miniconda3/etc/profile.d/conda.sh
conda activate qiime2-moshpit-2025.7

IN_DIR="/home/jtay0094/DNA_sequences/kneaddata/healthy1"
OUT_BASE="/home/jtay0094/DNA_sequences/assembly/healthy1"

mkdir -p "$OUT_BASE"
shopt -s nullglob

# Paired-only naming: <sample>_paired_1.fastq
P1_FILES=("$IN_DIR"/*_paired_1.fastq)

if [[ ${#P1_FILES[@]} -eq 0 ]]; then
  echo "ERROR: No '*_paired_1.fastq' files found in $IN_DIR" >&2
  exit 1
fi

for P1 in "${P1_FILES[@]}"; do
  base=$(basename "$P1")
  sample="${base%%_paired_1.fastq}"
  P2="$IN_DIR/${sample}_paired_2.fastq"

  if [[ ! -f "$P2" ]]; then
    echo "WARNING: Missing paired_2 for sample '$sample' — skipping"
    echo "  Expected: $P2"
    continue
  fi

  SAMPLE_DIR="$OUT_BASE/$sample"
  MEGAHIT_DIR="$SAMPLE_DIR/megahit"
  CONTIGS="$MEGAHIT_DIR/final.contigs.fa"
  QUAST_DIR="$SAMPLE_DIR/quast"

  mkdir -p "$SAMPLE_DIR"

  echo "==============================================="
  echo "Sample: $sample"
  echo "P1: $P1"
  echo "P2: $P2"
  echo "MEGAHIT OUT: $MEGAHIT_DIR"
  echo "QUAST OUT:   $QUAST_DIR"
  echo "==============================================="

  # ----- MEGAHIT -----
  if [[ -f "$CONTIGS" ]]; then
    echo "MEGAHIT contigs already exist for $sample — skipping assembly"
  else
    # If a previous failed run left the directory behind, remove it so MEGAHIT won't complain
    if [[ -d "$MEGAHIT_DIR" ]]; then
      echo "Found existing MEGAHIT output dir without final contigs; removing: $MEGAHIT_DIR"
      rm -rf "$MEGAHIT_DIR"
    fi

    megahit \
      -1 "$P1" \
      -2 "$P2" \
      -o "$MEGAHIT_DIR" \
      -t "$SLURM_CPUS_PER_TASK" \
      --presets meta-sensitive \
      --min-contig-len 500
  fi

  # ----- QUAST -----
  if [[ -f "$CONTIGS" ]]; then
    if [[ -f "$QUAST_DIR/report.html" || -f "$QUAST_DIR/report.tsv" || -f "$QUAST_DIR/report.txt" ]]; then
      echo "QUAST report already exists for $sample — skipping QUAST"
    else
      echo "Running QUAST for $sample ..."
      mkdir -p "$QUAST_DIR"
      quast.py "$CONTIGS" \
        -o "$QUAST_DIR" \
        -t "$SLURM_CPUS_PER_TASK" \
        --min-contig 500
    fi
  else
    echo "WARNING: Contigs not found for $sample ($CONTIGS). Skipping QUAST."
  fi

  echo "Done $sample"
  echo
done

echo "All MEGAHIT assemblies (and QUAST where applicable) completed."

