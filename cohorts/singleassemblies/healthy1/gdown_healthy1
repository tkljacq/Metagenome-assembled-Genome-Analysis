#!/bin/bash
#SBATCH --job-name=gdown_healthy1
#SBATCH --output=/home/jtay0094/gdown_healthy1_%j.out
#SBATCH --error=/home/jtay0094/gdown_healthy1_%j.err
#SBATCH --time=2-00:00:00
#SBATCH --mem=4G
#SBATCH --cpus-per-task=1

# don't exit on first failure, but still be strict on unset vars / pipes
set -uo pipefail

GDOWN_BIN="$HOME/.conda/envs/metaprep/bin/gdown"

# where to save the freshly re-downloaded reads
TARGET_DIR="/home/jtay0094/DNA_sequences/rawreads/healthy1"
mkdir -p "$TARGET_DIR"

# your ID list for healthy1
FILE_ID_LIST="/home/jtay0094/healthy1_ids"

# optional: log of any files that still fail after retries
FAILED_IDS_LOG="$TARGET_DIR/gdown_failed_ids_healthy1.log"
: > "$FAILED_IDS_LOG"

echo "Starting downloads into: $TARGET_DIR"
cd "$TARGET_DIR"

while read -r FILE_ID; do
    [[ -z "$FILE_ID" ]] && continue

    echo "---------------------------------------"
    echo "Downloading file ID: $FILE_ID"
    echo "---------------------------------------"

    attempts=0
    max_attempts=3
    success=0

    while [[ $attempts -lt $max_attempts ]]; do
        attempts=$((attempts + 1))
        echo "  Attempt $attempts of $max_attempts"

        "$GDOWN_BIN" "https://drive.google.com/uc?id=${FILE_ID}" \
            --continue --fuzzy

        rc=$?
        if [[ $rc -eq 0 ]]; then
            echo "  Success: $FILE_ID"
            success=1
            break
        else
            echo "  gdown failed for $FILE_ID (exit code $rc)"
            [[ $attempts -lt $max_attempts ]] && \
                echo "  Retrying in 60s..." && sleep 60
        fi
    done

    if [[ $success -eq 0 ]]; then
        echo "FAILED: $FILE_ID" | tee -a "$FAILED_IDS_LOG"
    fi

    echo
done < "$FILE_ID_LIST"

echo "All downloads attempted."
echo "Any failures recorded in: $FAILED_IDS_LOG"

