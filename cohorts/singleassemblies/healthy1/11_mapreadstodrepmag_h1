#!/bin/bash
#SBATCH --job-name=map_derep098_h1
#SBATCH --partition=highprio
#SBATCH --output=/home/jtay0094/11_map_derep098_h1_%j.out
#SBATCH --error=/home/jtay0094/11_map_derep098_h1_%j.err
#SBATCH --time=8-00:00:00
#SBATCH --cpus-per-task=6
#SBATCH --mem=112G

set -eo pipefail
echo "START: $(date)"

source /home/jtay0094/miniconda3/etc/profile.d/conda.sh
conda activate qiime2-moshpit-2025.7

THREADS="${SLURM_CPUS_PER_TASK}"
SEED="100"

BASE="/home/jtay0094/MAGs/healthy1"
READS_QZA="$BASE/assembly/indexmap/reads.qza"

OUTDIR="$BASE/binning/abundance_derep098"
INDEX_QZA="$OUTDIR/mags_derep098_index.qza"
ALN_QZA="$OUTDIR/reads_to_derep098_mags.qza"

[[ -f "$INDEX_QZA" ]] || { echo "ERROR: Missing $INDEX_QZA (run index job first)" >&2; exit 1; }
[[ -f "$READS_QZA" ]] || { echo "ERROR: Missing $READS_QZA" >&2; exit 1; }

if [[ -f "$ALN_QZA" ]]; then
  echo "Alignment already exists — skipping: $ALN_QZA"
  echo "END: $(date)"
  exit 0
fi

mosh assembly map-reads \
  --i-index "$INDEX_QZA" \
  --i-reads "$READS_QZA" \
  --p-threads "$THREADS" \
  --p-seed "$SEED" \
  --o-alignment-maps "$ALN_QZA" \
  --verbose

echo "END: $(date)"
echo "Alignment: $ALN_QZA"
