#!/bin/bash
#SBATCH --job-name=knead_missing
#SBATCH --output=/home/jtay0094/kneaddata_missing_%j.out
#SBATCH --error=/home/jtay0094/kneaddata_missing_%j.err
#SBATCH --time=3-00:00:00
#SBATCH --cpus-per-task=4
#SBATCH --mem=32G

set -eo pipefail

source /home/jtay0094/miniconda3/etc/profile.d/conda.sh
conda activate metaprep

RAW_DIR="/home/jtay0094/DNA_sequences/rawreads/missing"
OUT_BASE="/home/jtay0094/DNA_sequences/kneaddata/missing"
DB_BOWTIE2="/home/jtay0094/databases/bowtie2"
TRIM_ADAPTERS="$CONDA_PREFIX/share/trimmomatic/adapters/NexteraPE-PE.fa"

FASTQC_DIR="$OUT_BASE/fastqc_paired"

mkdir -p "$OUT_BASE" "$FASTQC_DIR"

shopt -s nullglob

R1_FILES=(
  "$RAW_DIR"/*_R1_001.fastq.gz
  "$RAW_DIR"/*_R1.fastq.gz
)

if [[ ${#R1_FILES[@]} -eq 0 ]]; then
  echo "ERROR: No R1 FASTQ.GZ files found in $RAW_DIR" >&2
  exit 1
fi

for R1 in "${R1_FILES[@]}"; do
  f=$(basename "$R1")

  sample=""
  R2=""

  if [[ "$f" =~ ^(.+)_R1_001\.fastq\.gz$ ]]; then
    sample="${BASH_REMATCH[1]}"
    R2="$RAW_DIR/${sample}_R2_001.fastq.gz"
  elif [[ "$f" =~ ^(.+)_R1\.fastq\.gz$ ]]; then
    sample="${BASH_REMATCH[1]}"
    R2="$RAW_DIR/${sample}_R2.fastq.gz"
  else
    echo "Skipping unrecognized R1 name: $f"
    continue
  fi

  if [[ ! -f "$R2" ]]; then
    echo "WARNING: Missing R2 for sample '$sample' — skipping"
    continue
  fi

  echo "==============================================="
  echo "Sample: $sample"
  echo "R1:     $R1"
  echo "R2:     $R2"
  echo "==============================================="

  kneaddata \
    -i1 "$R1" \
    -i2 "$R2" \
    -o "$OUT_BASE" \
    --output-prefix "$sample" \
    -db "$DB_BOWTIE2" \
    -t "$SLURM_CPUS_PER_TASK" \
    --run-trf \
    --trimmomatic-options \
      "ILLUMINACLIP:${TRIM_ADAPTERS}:2:30:10:8:true \
       LEADING:3 TRAILING:3 SLIDINGWINDOW:4:20 MINLEN:90"

  echo "Finished kneaddata for $sample"
  echo "Cleaning up (keeping trimmed + final outputs)..."

  # Remove host-contam FASTQs (human-mapped reads)
  rm -f "$OUT_BASE/${sample}"*_hg39_bowtie2_*contam*.fastq

  # Remove TRF repeat-filter intermediate files
  rm -f "$OUT_BASE/${sample}.repeats.removed."*.fastq
  rm -f "$OUT_BASE/${sample}_kneaddata.repeats.removed."*.fastq

  echo "Running FastQC (paired outputs only) for $sample ..."

  P1="$OUT_BASE/${sample}_kneaddata_paired_1.fastq"
  P2="$OUT_BASE/${sample}_kneaddata_paired_2.fastq"

  if [[ -f "$P1" && -f "$P2" ]]; then
    fastqc -t "$SLURM_CPUS_PER_TASK" -o "$FASTQC_DIR" "$P1" "$P2"
  else
    echo "WARNING: Paired output FASTQs not found for $sample, skipping FastQC"
  fi

  echo "Done $sample"
  echo
done

echo "Kneaddata processing complete for missing samples."

