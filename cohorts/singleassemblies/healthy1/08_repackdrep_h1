#!/bin/bash
#SBATCH --job-name=repack_derep098_h1
#SBATCH --partition=highprio
#SBATCH --output=/home/jtay0094/repack_derep098_h1_%j.out
#SBATCH --error=/home/jtay0094/repack_derep098_h1_%j.err
#SBATCH --time=02:00:00
#SBATCH --cpus-per-task=2
#SBATCH --mem=8G

set -eo pipefail
echo "START: $(date)"

source /home/jtay0094/miniconda3/etc/profile.d/conda.sh
conda activate qiime2-moshpit-2025.7

BASE="/home/jtay0094/MAGs/healthy1"

# ---- Input derep output (FeatureData[MAG]) ----
IN_DEREP="$BASE/binning/derep_thr098/mags_derep.qza"

# ---- Output repacked artifact (SampleData[MAGs]) ----
OUT_QZA="$BASE/binning/derep_thr098/mags_derep_sampledata.qza"

# ---- Work dirs ----
WORK="$BASE/binning/derep_thr098/repack"
EXPORT_DIR="$WORK/export"
WRAP_DIR="$WORK/mags_derep_sampledata_dir"

[[ -f "$IN_DEREP" ]] || { echo "ERROR: Missing $IN_DEREP" >&2; exit 1; }

# Skip if already done
if [[ -f "$OUT_QZA" ]]; then
  echo "Repacked artifact already exists — skipping."
  qiime tools peek "$OUT_QZA"
  echo "END: $(date)"
  exit 0
fi

rm -rf "$WORK"
mkdir -p "$WORK"

echo "Exporting derep MAGs..."
qiime tools export \
  --input-path "$IN_DEREP" \
  --output-path "$EXPORT_DIR"

# Wrap into MultiMAGSequencesDirFmt
rm -rf "$WRAP_DIR"
mkdir -p "$WRAP_DIR/data"

cp "$EXPORT_DIR"/*.fasta "$WRAP_DIR/data/"

echo "sample-id,mag-id,filename" > "$WRAP_DIR/MANIFEST"
for f in "$WRAP_DIR"/data/*.fasta; do
  id="$(basename "$f" .fasta)"
  echo "DEREP098,${id},data/${id}.fasta"
done >> "$WRAP_DIR/MANIFEST"

echo "Importing as SampleData[MAGs]..."
qiime tools import \
  --type 'SampleData[MAGs]' \
  --input-path "$WRAP_DIR" \
  --input-format MultiMAGSequencesDirFmt \
  --output-path "$OUT_QZA"

echo "Repacked MAGs created:"
qiime tools peek "$OUT_QZA"

echo "END: $(date)"
echo "Output: $OUT_QZA"
