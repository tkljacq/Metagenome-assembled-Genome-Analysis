#!/bin/bash
#SBATCH --job-name=busco_h1
#SBATCH --partition=cpu1.largem
#SBATCH --output=/home/jtay0094/busco_h1_%j.out
#SBATCH --error=/home/jtay0094/busco_h1_%j.err
#SBATCH --time=2-00:00:00
#SBATCH --cpus-per-task=16
#SBATCH --mem=128G

set -eo pipefail

source /home/jtay0094/miniconda3/etc/profile.d/conda.sh
conda activate qiime2-moshpit-2025.7

CPU="${SLURM_CPUS_PER_TASK}"
LINEAGE="bacteria_odb12"

# Input MAGs from your binning step
BIN_DIR="/home/jtay0094/DNA_sequences/assembly/binning/healthy1"
MAGS_QZA="${BIN_DIR}/mags.qza"

# Output directory for BUSCO
OUT_DIR="/home/jtay0094/DNA_sequences/assembly/busco/healthy1"
mkdir -p "$OUT_DIR"

BUSCO_DB_QZA="${OUT_DIR}/busco_db.qza"
BUSCO_RESULTS_QZA="${OUT_DIR}/busco_results.qza"
BUSCO_VIZ_QZV="${OUT_DIR}/mags_busco.qzv"

# Sanity checks
[[ -f "$MAGS_QZA" ]] || { echo "ERROR: Missing MAGs artifact: $MAGS_QZA" >&2; exit 1; }

# 1) Fetch BUSCO DB (only once)
if [[ ! -f "$BUSCO_DB_QZA" ]]; then
  mosh annotate fetch-busco-db \
    --p-lineages "$LINEAGE" \
    --o-db "$BUSCO_DB_QZA" \
    --verbose
fi

# 2) Evaluate MAGs with BUSCO
if [[ ! -f "$BUSCO_RESULTS_QZA" || ! -f "$BUSCO_VIZ_QZV" ]]; then
  mosh annotate evaluate-busco \
    --i-mags "$MAGS_QZA" \
    --i-db "$BUSCO_DB_QZA" \
    --p-lineage-dataset "$LINEAGE" \
    --p-cpu "$CPU" \
    --o-visualization "$BUSCO_VIZ_QZV" \
    --o-results "$BUSCO_RESULTS_QZA" \
    --verbose
fi

echo "Done."
echo "BUSCO results: $BUSCO_RESULTS_QZA"
echo "BUSCO viz:     $BUSCO_VIZ_QZV"

