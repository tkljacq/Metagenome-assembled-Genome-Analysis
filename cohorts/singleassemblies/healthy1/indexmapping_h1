#!/bin/bash
#SBATCH --job-name=indexmap_h1
#SBATCH --partition=cpu1.largem
#SBATCH --output=/home/jtay0094/indexmap_h1_%j.out
#SBATCH --error=/home/jtay0094/indexmap_h1_%j.err
#SBATCH --time=2-00:00:00
#SBATCH --cpus-per-task=4
#SBATCH --mem=128G

set -eo pipefail

source /home/jtay0094/miniconda3/etc/profile.d/conda.sh
conda activate qiime2-moshpit-2025.7

THREADS="${SLURM_CPUS_PER_TASK}"
SEED="100"

CONTIG_DIR="/home/jtay0094/DNA_sequences/assembly/contigs"
READS_DIR="/home/jtay0094/DNA_sequences/kneaddata/healthy1"

OUT_BASE="/home/jtay0094/DNA_sequences/assembly/indexmapping"
mkdir -p "$OUT_BASE"

CONTIG_QZA="$OUT_BASE/contigs.qza"
INDEX_QZA="$OUT_BASE/contigs-index.qza"
READS_QZA="$OUT_BASE/reads.qza"
ALN_QZA="$OUT_BASE/reads-to-contigs-aln.qza"

# Temp casava dir (node-local scratch if available)
CASAVA_DIR="${SLURM_TMPDIR:-$OUT_BASE}/casava_reads"
mkdir -p "$CASAVA_DIR"

gzip_cmd() {
  if command -v pigz >/dev/null 2>&1; then
    pigz -p "$THREADS" -c "$1" > "$2"
  else
    gzip -c "$1" > "$2"
  fi
}

# 1) Import contigs
if [[ ! -f "$CONTIG_QZA" ]]; then
  qiime tools import \
    --type 'SampleData[Contigs]' \
    --input-path "$CONTIG_DIR" \
    --output-path "$CONTIG_QZA"
fi

# 2) Index contigs
if [[ ! -f "$INDEX_QZA" ]]; then
  mosh assembly index-contigs \
    --i-contigs "$CONTIG_QZA" \
    --p-threads "$THREADS" \
    --p-seed "$SEED" \
    --o-index "$INDEX_QZA" \
    --verbose
fi

# 3) Build Casava-formatted, gzipped reads (no manifest)
if [[ ! -f "$READS_QZA" ]]; then
  rm -rf "$CASAVA_DIR"
  mkdir -p "$CASAVA_DIR"

  shopt -s nullglob
  P1_FILES=("$READS_DIR"/*_paired_1.fastq)

  if [[ ${#P1_FILES[@]} -eq 0 ]]; then
    echo "ERROR: No paired reads found in $READS_DIR (*_paired_1.fastq)" >&2
    exit 1
  fi

  for P1 in "${P1_FILES[@]}"; do
    base=$(basename "$P1")
    sample="${base%%_paired_1.fastq}"
    P2="$READS_DIR/${sample}_paired_2.fastq"

    if [[ ! -f "$P2" ]]; then
      echo "WARNING: Missing paired_2 for $sample — skipping"
      continue
    fi

    outR1="$CASAVA_DIR/${sample}_S1_L001_R1_001.fastq.gz"
    outR2="$CASAVA_DIR/${sample}_S1_L001_R2_001.fastq.gz"

    echo "Preparing Casava reads for $sample"
    gzip_cmd "$P1" "$outR1"
    gzip_cmd "$P2" "$outR2"
  done

  qiime tools import \
    --type 'SampleData[PairedEndSequencesWithQuality]' \
    --input-path "$CASAVA_DIR" \
    --input-format CasavaOneEightSingleLanePerSampleDirFmt \
    --output-path "$READS_QZA"
fi

# 4) Map reads to contigs
if [[ ! -f "$ALN_QZA" ]]; then
  mosh assembly map-reads \
    --i-index "$INDEX_QZA" \
    --i-reads "$READS_QZA" \
    --p-threads "$THREADS" \
    --p-seed "$SEED" \
    --o-alignment-maps "$ALN_QZA" \
    --verbose
fi

echo "Done."

